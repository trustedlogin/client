# Auto detect text files and perform LF normalization
* text=auto

# Exclude from published package (composer dist, GitHub source archives).
# Anything not strictly required to RUN the SDK on a consumer's site is
# excluded — source maps leak internal layout, dev configs add weight,
# and CI / agent / docs configs are local-tooling concerns the consumer
# should never have to look at.

# Source-map and dotfile cruft.
*.css.map               export-ignore
.gitattributes          export-ignore
.gitignore              export-ignore
.editorconfig           export-ignore
.travis.yml             export-ignore
.wp-env.json            export-ignore
.coderabbit.yaml        export-ignore
.distignore             export-ignore

# Test suite + its configs.
tests/                  export-ignore
phpunit.xml.dist        export-ignore
phpunit-unit.xml        export-ignore
.phpunit-watcher.yml    export-ignore

# Static-analysis tooling configs.
.phpcs.xml.dist         export-ignore
phpstan.neon.dist       export-ignore
bin/install-wp-tests.sh export-ignore
bin/phpstan-bootstrap.php export-ignore

# Front-end / docs build configs (the consumer doesn't rebuild assets).
mkdocs.yml              export-ignore

# CI and agent / repo-housekeeping files.
.github/                export-ignore
.claude/                export-ignore
AGENTS.md               export-ignore
pull_request_template.md export-ignore

